{
  "name": "@ottimis/capacitor-ios-app-tracking",
  "version": "1.0.0",
  "description": "App Tracking Transparency (ATT) plugin for Capacitor 7 — iOS only",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "files": [
    "dist/",
    "ios/",
    "OttimisCapacitorTrackingTransparency.podspec"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "ios",
    "tracking",
    "att",
    "app-tracking-transparency",
    "privacy"
  ],
  "author": "Ottimis <dev@ottimis.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ottimis/capacitor-tracking-transparency.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    }
  },
  "devDependencies": {
    "@capacitor/core": "^7.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  }
}
